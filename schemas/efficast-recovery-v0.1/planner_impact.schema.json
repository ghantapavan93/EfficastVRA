{
  "$defs": {
    "DataQuality": {
      "enum": [
        "OK",
        "SUSPECT",
        "MISSING",
        "STALE"
      ],
      "title": "DataQuality",
      "type": "string"
    }
  },
  "properties": {
    "source_system": {
      "title": "Source System",
      "type": "string"
    },
    "schema_version": {
      "default": "0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "mapping_version": {
      "default": "0.1",
      "title": "Mapping Version",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "plant_id": {
      "title": "Plant Id",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "correlation_id": {
      "title": "Correlation Id",
      "type": "string"
    },
    "idempotency_key": {
      "title": "Idempotency Key",
      "type": "string"
    },
    "source_timestamp": {
      "format": "date-time",
      "title": "Source Timestamp",
      "type": "string"
    },
    "ingestion_timestamp": {
      "format": "date-time",
      "title": "Ingestion Timestamp",
      "type": "string"
    },
    "timezone": {
      "default": "UTC",
      "title": "Timezone",
      "type": "string"
    },
    "data_quality": {
      "$ref": "#/$defs/DataQuality",
      "default": "OK"
    },
    "event_type": {
      "const": "planner_impact",
      "default": "planner_impact",
      "title": "Event Type",
      "type": "string"
    },
    "order_id": {
      "default": "",
      "title": "Order Id",
      "type": "string"
    },
    "delay_minutes": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Delay Minutes"
    },
    "downstream_orders": {
      "items": {
        "type": "string"
      },
      "title": "Downstream Orders",
      "type": "array"
    },
    "note": {
      "default": "",
      "title": "Note",
      "type": "string"
    }
  },
  "required": [
    "source_system",
    "tenant_id",
    "plant_id",
    "source_id",
    "correlation_id",
    "idempotency_key",
    "source_timestamp",
    "ingestion_timestamp"
  ],
  "title": "PlannerImpact",
  "type": "object"
}
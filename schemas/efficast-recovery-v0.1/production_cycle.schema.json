      "title": "Event Type",
      "type": "string"
    },
    "machine_id": {
      "title": "Machine Id",
      "type": "string"
    },
    "order_id": {
      "default": "",
      "title": "Order Id",
      "type": "string"
    },
    "cycle_index": {
      "default": 0,
      "title": "Cycle Index",
      "type": "integer"
    },
    "cycle_time_s": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cycle Time S"
    },
    "good_count": {
      "default": 0,
      "title": "Good Count",
      "type": "integer"
    },
    "scrap_count": {
      "default": 0,
      "title": "Scrap Count",
      "type": "integer"
    },
    "fault_code": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Fault Code"
    }
  },
  "required": [
    "source_system",
    "tenant_id",
    "plant_id",
    "source_id",
    "correlation_id",
    "idempotency_key",
    "source_timestamp",
    "ingestion_timestamp",
    "machine_id"

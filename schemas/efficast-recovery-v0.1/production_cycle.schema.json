      "title": "Schema Version",
      "type": "string"
    },
    "mapping_version": {
      "default": "0.1",
      "title": "Mapping Version",
      "type": "string"
    },
    "tenant_id": {
      "title": "Tenant Id",
      "type": "string"
    },
    "plant_id": {
      "title": "Plant Id",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "correlation_id": {
      "title": "Correlation Id",
      "type": "string"
    },
    "idempotency_key": {
      "title": "Idempotency Key",
      "type": "string"
    },
    "source_timestamp": {
      "format": "date-time",
      "title": "Source Timestamp",
      "type": "string"
    },
    "ingestion_timestamp": {
      "format": "date-time",
      "title": "Ingestion Timestamp",
      "type": "string"
    },
    "timezone": {
      "default": "UTC",

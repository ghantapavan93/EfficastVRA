# Copy to .env to override defaults. The demo runs with ALL defaults (no secrets needed).

# Environment label shown in the UI ("synthetic-demo" enables the demo controller).
VRA_ENV=synthetic-demo

# Default: file-backed SQLite (zero infra). Production example:
#   VRA_DATABASE_URL=postgresql+psycopg://vra:vra@localhost:5432/vra
VRA_DATABASE_URL=sqlite:///./var/vra.db

# Tenant / plant scope for the synthetic deployment.
VRA_TENANT=northstar
VRA_PLANT=PLANT-NS

# Reasoning provider: "deterministic" (default, no key) | "hosted" | "local"
VRA_REASONING=deterministic
# Only used when VRA_REASONING=hosted (optional; demo never depends on it):
# VRA_REASONING_BASE_URL=https://api.anthropic.com
# VRA_REASONING_API_KEY=
# VRA_REASONING_MODEL=claude-opus-4-8

# Enable the demo controller endpoints (1/0). Should be 0 in production.
VRA_DEMO_MODE=1

# CORS origin for the Next.js frontend.
VRA_FRONTEND_ORIGIN=http://localhost:3000

# Policy / workflow / prompt versions (surfaced in audit + UI).
VRA_POLICY_VERSION=policy-2026.06
VRA_WORKFLOW_VERSION=wf-1

# ── Security hardening (defense-in-depth). All limits are PROTOTYPE_ASSUMPTIONs; live at /api/security.
# Hardening response headers (CSP/nosniff/frame-deny/COOP-CORP/Permissions-Policy). 1/0.
VRA_SECURITY_HEADERS=1
# HSTS — only meaningful once TLS terminates here/upstream. Off by default. 1/0.
VRA_SECURITY_HSTS=0
# Per-identity rate limiting (request flooding / abuse). 1/0 + limit/window.
VRA_RATE_LIMIT=1
VRA_RATE_LIMIT_REQUESTS=600
VRA_RATE_LIMIT_WINDOW_S=60
# Reject request bodies larger than this many bytes (oversized-payload DoS). Default 1 MiB.
VRA_MAX_BODY_BYTES=1048576
# Keyed audit signing. Empty = OFF (the SHA-256 hash chain still runs). Set a strong secret
# (from a vault/KMS in production) to make the audit trail unforgeable without the key.
# VRA_AUDIT_HMAC_KEY=change-me-to-a-long-random-secret
